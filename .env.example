# ===========================================
# Debts App — Environment Variables
# ===========================================
# Copia este archivo como .env y reemplaza los valores
# cp .env.example .env

# --- Database (PostgreSQL) ---
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/debts_app"

# --- JWT Secrets ---
# Genera strings largas y aleatorias (recomendado: openssl rand -hex 32)
JWT_SECRET="change-me-to-a-random-secret-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-to-another-random-secret-at-least-32-chars"

# --- Server ---
PORT=4000

# --- CORS ---
# URL del frontend en desarrollo
CLIENT_URL="http://localhost:5173"

# --- Uploadthing (opcional) ---
# Para subida de imágenes de comprobante de pago.
# Crea una cuenta gratis en https://uploadthing.com
UPLOADTHING_APP_ID=""
UPLOADTHING_SECRET=""
